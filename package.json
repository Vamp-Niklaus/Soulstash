{
  "name": "soulstash-movie-app",
  "version": "1.1.0",
  "description": "Movie streaming app with collections",
  "main": "server.js",
  "scripts": {
    "build": "vite build --configLoader native",
    "dev": "concurrently \"npm run dev:microservices\" \"npm run dev:client\"",
    "dev:client": "vite --configLoader native",
    "dev:microservices": "concurrently \"ts-node services/api-gateway/src/index.ts\" \"ts-node services/user-service/src/index.ts\" \"ts-node services/content-service/src/index.ts\" \"ts-node services/collection-service/src/index.ts\" \"ts-node services/scraper-service/src/index.ts\"",
    "postinstall": "npx playwright install chromium",
    "render-build": "npm install --include=dev && npx playwright install chromium && npm run build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/screen-orientation": "^8.0.1",
    "@videojs/react": "^10.0.0-beta.5",
    "acorn": "^8.16.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fetch": "^1.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.0",
    "playwright": "^1.61.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-masonry-css": "^1.0.16",
    "react-router-dom": "^7.14.0",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.7"
  },
  "engines": {
    "node": "20.x"
  }
}
